# Telegram
TELEGRAM_BOT_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_ID=          # person:<id> or organization:<id>

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=         # e.g. https://marketing.vercel.app
INTERNAL_SECRET=             # any random string, guards /api/linkedin/process

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=           # folder containing marketing images

# Meta Ads (Ads dashboard — optional)
FACEBOOK_ADS_ACCESS_TOKEN=   # token with the ads_read permission (ads_management too, to pause campaigns)
FACEBOOK_AD_ACCOUNT_ID=      # one or more, comma-separated, e.g. 825509324768778,1210401510547130 (act_ prefix added automatically)
